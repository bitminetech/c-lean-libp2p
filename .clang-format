---
# c-lean-libp2p formatting rules
# Run: clang-format -i src/**/*.c include/**/*.h
# Verify: clang-format --dry-run --Werror src/**/*.c include/**/*.h

Language: C
BasedOnStyle: LLVM

# Allman braces — opening brace on its own line
BreakBeforeBraces: Allman

# 4-space indentation, no tabs
IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4

# 100-column line width
ColumnLimit: 100

# One parameter per line when wrapping, indented 4 spaces after break
AlignAfterOpenBracket: AlwaysBreak
BinPackArguments: false
BinPackParameters: false
AllowAllParametersOfDeclarationOnNextLine: false
AllowAllArgumentsOnNextLine: false

# Pointer alignment: right-aligned (uint8_t *out, not uint8_t* out)
PointerAlignment: Right

# Keep single-line blocks (e.g. short returns) on one line when they fit
AllowShortBlocksOnASingleLine: Empty
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false

# Include ordering: main header first, then system, then project
SortIncludes: CaseInsensitive
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^"libp2p_'
    Priority: 2
  - Regex: '^<'
    Priority: 1
  - Regex: '.*'
    Priority: 3

# Spacing
SpaceAfterCStyleCast: false
SpaceBeforeParens: ControlStatements
SpacesInParentheses: false
SpaceBeforeSquareBrackets: false

# Alignment
AlignConsecutiveMacros: Consecutive
AlignConsecutiveAssignments: None
AlignConsecutiveDeclarations: None
AlignEscapedNewlines: Left
AlignOperands: Align
AlignTrailingComments: true

# Braces and blocks
IndentCaseLabels: false
IndentGotoLabels: false

# Penalties — prefer wrapping parameters over exceeding column limit
PenaltyBreakBeforeFirstCallParameter: 200
PenaltyExcessCharacter: 1000000
PenaltyReturnTypeOnItsOwnLine: 10000
...
